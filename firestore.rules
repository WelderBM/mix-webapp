rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────
    // Função auxiliar: verifica se o usuário autenticado é um funcionário autorizado
    // Requisitos:
    // 1. Estar autenticado
    // 2. Email verificado
    // 3. Email presente na coleção /whitelisted_staff/{email}
    // ─────────────────────────────────────────────────────────────────────
    function isAdmin() {
      let email = request.auth.token.email;
      let isVerified = request.auth != null && request.auth.token.email_verified == true;
      
      // 1. Check individual whitelist
      let whitelisted = exists(/databases/$(database)/documents/whitelisted_staff/$(email)) &&
                        get(/databases/$(database)/documents/whitelisted_staff/$(email)).data.active == true;
      
      // 2. Check corporate domain
      let hasSettings = exists(/databases/$(database)/documents/settings/general);
      let domainWhitelist = hasSettings && 
                             get(/databases/$(database)/documents/settings/general).data.allowedStaffDomain != null &&
                             email.lower().matches('.*@' + get(/databases/$(database)/documents/settings/general).data.allowedStaffDomain.lower() + '$');

      return isVerified && (whitelisted || domainWhitelist);
    }

    // ─────────────────────────────────────────────────────────────────────
    // /products/{productId}
    //   - Leitura: pública (catálogo visível sem login)
    //   - Escrita:  somente admin
    // ─────────────────────────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────
    // /orders/{orderId}
    //   - Criar:   público (qualquer pessoa pode fazer pedido)
    //   - Ler:     admin OU o próprio dono (via customerPhone)
    //   - Atualizar/Deletar: somente admin
    // ─────────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow create: if true;
      allow read:   if isAdmin() ||
                       (request.auth == null &&
                        resource.data.customerPhone == request.resource.data.customerPhone);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────
    // /settings/{doc}  (configurações gerais da loja, temas, balões, etc.)
    //   - Leitura: pública (necessária para renderizar a loja)
    //   - Escrita:  somente admin
    // ─────────────────────────────────────────────────────────────────────
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────
    // /kitRecipes/{recipeId}
    //   - Leitura: pública (usada pelo Kit Builder)
    //   - Escrita:  somente admin
    // ─────────────────────────────────────────────────────────────────────
    match /kitRecipes/{recipeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────
    // /users/{userId}
    //   - Ler/escrever o próprio perfil: usuário autenticado
    //   - Ler qualquer perfil: somente admin (para verificação de roles)
    //   - Escrever role: somente admin (evita auto-promoção)
    // ─────────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if request.auth != null &&
                       (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
                       request.auth.uid == userId &&
                       !("role" in request.resource.data);   // não pode alterar o próprio role
      allow update: if isAdmin();                             // admin pode alterar qualquer campo
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────
    // /whitelisted_staff/{email}
    //   - Somente admin pode ler/escrever
    // ─────────────────────────────────────────────────────────────────────
    match /whitelisted_staff/{email} {
      allow read, write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────
    // Nega tudo o que não for coberto pelas regras acima
    // ─────────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
