rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Regra para imagens de produtos e da loja:
    // Qualquer pessoa pode LER (ver as fotos no site).
    // Apenas usuários autenticados (Admins) podem CRIAR, EDITAR ou DELETAR.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
