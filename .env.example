# ─────────────────────────────────────────────────────────────────────────────
# Configurações do Firebase
# Copie este arquivo como .env.local e preencha com os valores do seu projeto.
#
# Para obter esses valores:
#   1. Acesse https://console.firebase.google.com
#   2. Selecione seu projeto → Configurações do Projeto → Seus aplicativos
#   3. Copie o objeto firebaseConfig
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# (Opcional) Measurement ID do Google Analytics — deixe vazio se não usar
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
